# ============= ENVIRONMENT =============
ENVIRONMENT=development
DEBUG_MODE=False
TIMEZONE=UTC

# ============= LOGGING =============
LOG_LEVEL=INFO

# ============= BINANCE API =============
BINANCE_API_KEY=tu_api_key_de_binance
BINANCE_API_SECRET=tu_api_secret_de_binance
USE_TESTNET=False

# ============= DATABASE PostgreSQL =============
DB_HOST=localhost
DB_PORT=5432
DB_USER=trading_user
DB_PASSWORD=secure_password_change_this
DB_NAME=xrp_trading_db

# ============= REDIS CACHE =============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============= EMAIL ALERTS (SendGrid) =============
SENDGRID_API_KEY=tu_sendgrid_api_key
SENDGRID_FROM_EMAIL=alertas@tudominio.com
SENDGRID_TO_EMAIL=tu_email@gmail.com
EMAIL_ALERTS_ENABLED=True

# ============= TELEGRAM ALERTS =============
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token
TELEGRAM_CHAT_ID=tu_telegram_chat_id
TELEGRAM_ALERTS_ENABLED=True

# ============= WEBHOOKS =============
WEBHOOK_SECRET=tu_webhook_secret_key
WEBHOOK_URLS=https://tu-servidor.com/webhook,https://zapier.com/hooks/catch/
WEBHOOK_ALERTS_ENABLED=True

# ============= AI/ML =============
MODEL_TRAINING_DATA_DAYS=365
PREDICTION_INTERVAL_HOURS=4,24
IA_CONFIDENCE_THRESHOLD=0.65

# ============= TRADING PARAMETERS =============
TRADING_SYMBOL=XRPUSDT
TRADING_INTERVAL=1h
MAX_ORDER_SIZE_USDT=500
MAX_ORDERS_PER_HOUR=50
STOP_LOSS_PERCENTAGE=2.0
TAKE_PROFIT_PERCENTAGE=5.0

# ============= SECURITY =============
ENCRYPTION_KEY=tu_encryption_key_aqui_cambiar_en_produccion
JWT_SECRET=tu_jwt_secret_key_cambiar_en_produccion

# ============= SISTEMA =============
USUARIO_EMAIL=tu_email@gmail.com
USUARIO_NOMBRE=Tu Nombre
